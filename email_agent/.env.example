# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── IMAP credentials ─────────────────────────────────────────────────────────
# Gmail:    IMAP_HOST=imap.gmail.com        IMAP_PORT=993
# Outlook:  IMAP_HOST=outlook.office365.com IMAP_PORT=993
# iCloud:   IMAP_HOST=imap.mail.me.com      IMAP_PORT=993
# Fastmail: IMAP_HOST=imap.fastmail.com     IMAP_PORT=993
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASS=your-app-password

# ─── Optional overrides ───────────────────────────────────────────────────────
# Override the Drafts folder name if auto-detection fails.
# Gmail example: [Gmail]/Drafts
# Outlook example: Drafts
DRAFTS_FOLDER=

# Claude model to use. Defaults to claude-haiku-4-5-20251001 (fast + cheap).
# Upgrade to claude-sonnet-4-6 for higher quality classifications.
CLAUDE_MODEL=claude-haiku-4-5-20251001
